# AWS
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# DynamoDB (auto-generated by serverless, shown for reference)
DYNAMODB_WORKERS_TABLE=whereismymistry-api-workers-dev
DYNAMODB_PHOTOS_TABLE=whereismymistry-api-photos-dev
DYNAMODB_REVIEWS_TABLE=whereismymistry-api-reviews-dev
DYNAMODB_LOCATIONS_TABLE=whereismymistry-api-locations-dev
DYNAMODB_CATEGORIES_TABLE=whereismymistry-api-categories-dev
DYNAMODB_OTP_TABLE=whereismymistry-api-otp-dev
DYNAMODB_ADMINS_TABLE=whereismymistry-api-admins-dev

# S3
S3_BUCKET_NAME=whereismymistry-api-uploads-dev

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Pinpoint (for production SMS)
PINPOINT_APP_ID=
PINPOINT_ORIGINATION_NUMBER=

# App
NODE_ENV=development
IS_OFFLINE=true
